# Turso database (production)
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Optional: local development falls back to server/data/rooms.db when unset.
# You can also point to a local file explicitly:
# TURSO_DATABASE_URL=file:server/data/rooms.db

# Server
PORT=3001

# Frontend (production build on Render — set on Static Site or via render.yaml fromService)
# VITE_API_URL=https://scotland-yard-8zor.onrender.com
# VITE_WS_URL is optional when VITE_API_URL is set (derived automatically)
