# Turso database (production)
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Optional: local development falls back to server/data/rooms.db when unset.
# You can also point to a local file explicitly:
# TURSO_DATABASE_URL=file:server/data/rooms.db

# Server (local development only — Fly.io sets PORT=8080 automatically)
PORT=3001
